generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model permission {
  id            String   @id
  shopId        String   @unique(map: "Permission_shopId_key")
  orders        Boolean  @default(false)
  products      Boolean  @default(false)
  customers     Boolean  @default(false)
  marketing     Boolean  @default(false)
  finance       Boolean  @default(false)
  analytics     Boolean  @default(false)
  termsAccepted Boolean  @default(false)
  updatedAt     DateTime
  shop          shop     @relation(fields: [shopId], references: [id], onDelete: Cascade, map: "Permission_shopId_fkey")
}

model session {
  id        String   @id
  shop      String
  data      String   @db.LongText
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model shop {
  id            String      @id
  shopDomain    String      @unique(map: "Shop_shopDomain_key")
  accessToken   String
  installedAt   DateTime
  uninstalledAt DateTime?
  ownerName     String?
  ownerEmail    String?
  phone         String?
  address1      String?
  city          String?
  province      String?
  country       String?
  zip           String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime
  permission    permission?
}
